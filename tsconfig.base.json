{
	"compilerOptions": {
		"target": "ES2023",
		"lib": ["ES2023"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"types": ["node"],
		"strict": true,
		"noUncheckedIndexedAccess": false,
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"erasableSyntaxOnly": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"skipLibCheck": true
	}
}
